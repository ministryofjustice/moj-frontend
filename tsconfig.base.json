{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "esModuleInterop": true,
    "module": "NodeNext",
    "noEmit": true,
    "noImplicitThis": true,
    "skipLibCheck": true,
    "strict": true,
    "types": []
  },
  "exclude": ["**/node_modules", "**/package"],
  "paths": {
    "@ministryofjustice/frontend": ["./src/moj/all.mjs"]
  },
  "typeAcquisition": {
    "enable": false
  }
}
