{% from "macros/heading/macro.njk" import heading %}
{% from "govuk/components/breadcrumbs/macro.njk" import govukBreadcrumbs %}
{% extends "./base.njk" %}

{% block header %}
    {% include "./partials/header-no-nav.njk" %}
{% endblock %}

{% block container %}

    <div class="app-layout__content">
        {{ govukBreadcrumbs({
  items: [
    {
      text: "Home",
      href: "/"
    }
    ]
    }) }}
        <main id="main-content" class="app-prose-scope">
  {{ heading({
        text: title
          }) }}
          {% block content %}
            {{ content | safe }}
          {% endblock %}
        </main>
    </div>
</div>
{% endblock %}
